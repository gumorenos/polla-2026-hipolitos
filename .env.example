# Database Connection String
# For local Windows development (relative to app/prisma/):
# DATABASE_URL="file:./prisma/dev.db?connection_limit=1&socket_timeout=20"
# For Raspberry Pi 5 production:
# DATABASE_URL="file:/var/lib/la-polla-2026/prod.db?connection_limit=1&socket_timeout=20"
DATABASE_URL="file:./prisma/dev.db"

# Better Auth Secret (Generate a random 32-byte hex string)
# You can generate one via: openssl rand -hex 32
BETTER_AUTH_SECRET="your-32-byte-hex-secret-goes-here"

# Application URL
# Local development: http://localhost:3030
# Production: https://pollahipolitos.todoestaaca.com
APP_URL="http://localhost:3030"
BETTER_AUTH_URL="http://localhost:3030"

# Public app URL exposed to the browser (used by the auth client)
# Must match the domain users access the app from
NEXT_PUBLIC_APP_URL="http://localhost:3030"

# Trusted Origins (Comma-separated list of additional URLs allowed to interact with auth)
# Example: TRUSTED_ORIGINS="https://pollahipolitos.todoestaaca.com,http://localhost:3030"
TRUSTED_ORIGINS=""

# Optional configurations
# Local development port: 3030
# Production port: 3030
# PORT=3030
# NODE_ENV=development

# Informational Market Probabilities & Odds Settings
ODDS_DISPLAY_ENABLED=false
ODDS_PRIMARY_PROVIDER=odds-api-io
ODDS_FALLBACK_PROVIDER=the-odds-api

# Odds-API.io Provider Configuration
ODDS_API_IO_ENABLED=false
ODDS_API_IO_KEY="your-odds-api-io-key"

# The Odds API Provider Configuration
THE_ODDS_API_ENABLED=false
THE_ODDS_API_KEY="your-the-odds-api-key"

# API-Football (H2H Statistics) Configuration
API_FOOTBALL_ENABLED=false
API_FOOTBALL_KEY="your-api-football-key"

# Odds Refresh & Simulation Controls
ODDS_GLOBAL_REFRESH_ENABLED=false
ODDS_MANUAL_USER_REFRESH_ENABLED=false
ODDS_ALLOW_SIMULATED_DATA=false

# Prediction Deadline Reminders (Email alerts via Resend)
REMINDERS_ENABLED=false
EMAIL_REMINDERS_ENABLED=false
REMINDER_MINUTES_BEFORE_DEADLINE=30
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM="La Polla Hipólitos <recordatorios@todoestaaca.com>"
REMINDERS_BATCH_LIMIT=50




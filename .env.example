# Database Connection String
# For local Windows development (relative to app/prisma/):
# DATABASE_URL="file:./prisma/dev.db?connection_limit=1&socket_timeout=20"
# For Raspberry Pi 5 production:
# DATABASE_URL="file:/var/lib/la-polla-2026/prod.db?connection_limit=1&socket_timeout=20"
DATABASE_URL="file:./prisma/dev.db"

# Better Auth Secret (Generate a random 32-byte hex string)
# You can generate one via: openssl rand -hex 32
BETTER_AUTH_SECRET="your-32-byte-hex-secret-goes-here"

# Application URL
# Local development: http://localhost:3000
# Production: https://lapolla.yourdomain.com
APP_URL="http://localhost:3000"
BETTER_AUTH_URL="http://localhost:3000"

# Optional configurations
# PORT=3000
# NODE_ENV=development

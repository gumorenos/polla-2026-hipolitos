# ─── Database ──────────────────────────────────────────────────────────────────
# Local dev: file:./prisma/dev.db?connection_limit=1&socket_timeout=20
# Production RPi5: /var/lib/la-polla-2026/prod.db
DATABASE_URL="file:./prisma/dev.db?connection_limit=1&socket_timeout=20"

# ─── Better Auth ───────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="change-this-to-a-secure-32+-char-secret"
BETTER_AUTH_URL="https://your-domain.com"
APP_URL="https://your-domain.com"
NEXT_PUBLIC_APP_URL="https://your-domain.com"
# Comma-separated trusted origins (no trailing slashes)
TRUSTED_ORIGINS="https://your-domain.com"

# ─── Email / Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="La Polla 2026 <noreply@yourdomain.com>"

# ─── Reminders ─────────────────────────────────────────────────────────────────
REMINDERS_ENABLED=false
EMAIL_REMINDERS_ENABLED=false

# ─── Odds Providers ────────────────────────────────────────────────────────────
ODDS_DISPLAY_ENABLED=false
ODDS_MANUAL_USER_REFRESH_ENABLED=false
ODDS_ALLOW_SIMULATED_DATA=false
ODDS_PRIMARY_PROVIDER="the-odds-api"
ODDS_FALLBACK_PROVIDER="odds-api-io"

# The Odds API (https://the-odds-api.com)
THE_ODDS_API_ENABLED=false
THE_ODDS_API_KEY=""
THE_ODDS_API_SPORT_KEY="soccer_fifa_world_cup"
THE_ODDS_API_REGIONS="us,eu"
THE_ODDS_API_MARKETS="h2h"

# Odds API IO (https://odds-api.io)
ODDS_API_IO_ENABLED=false
ODDS_API_IO_KEY=""
ODDS_API_IO_SPORT="football"
ODDS_API_IO_LEAGUE="1"

# ─── API-Football (https://api-sports.io) ──────────────────────────────────────
# Used for H2H and result fetching
API_FOOTBALL_ENABLED=false
API_FOOTBALL_KEY=""

# ─── football-data.org ─────────────────────────────────────────────────────────
# Free plan covers WC. See: https://www.football-data.org/documentation/quickstart
FOOTBALL_DATA_ENABLED=false
FOOTBALL_DATA_API_KEY=""
FOOTBALL_DATA_BASE_URL="https://api.football-data.org/v4"
FOOTBALL_DATA_COMPETITION_CODE="WC"

# ─── Results Fetching ──────────────────────────────────────────────────────────
# Master switch. Set to true in production to enable automated result fetching.
RESULTS_FETCH_ENABLED=false
# Provider chain (comma-separated, tried in order)
RESULTS_PROVIDER_CHAIN="api-football,football-data"
# Delay before considering a match's result fetchable (minutes after kickoff)
RESULTS_FETCH_DELAY_MINUTES_GROUPS=150
RESULTS_FETCH_DELAY_MINUTES_KNOCKOUT=210
# Max matches processed per script run
RESULTS_BATCH_LIMIT=20

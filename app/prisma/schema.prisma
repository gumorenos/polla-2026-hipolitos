generator client {
  provider = "prisma-client-js"
}


enum CompetitionType {
  full_prediction
  champion_survivor
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── AUTHENTICATION (Better Auth Models) ──────────────────────────────────────

model User {
  // Existing fields above
  championPicks        ChampionPick[]        @relation("UserChampionPicks")
  teamTournamentStatuses TeamTournamentStatus[] @relation("UserTeamStatuses")
  championOddsSnapshots ChampionOddsSnapshot[] @relation("UserOddsSnapshots")
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  // Custom User fields
  username         String?   @unique
  displayUsername  String?
  status           String    @default("pending") // "pending" | "approved" | "rejected" | "disabled"
  canCreateLeagues Boolean   @default(false)
  displayName      String?
  whatsapp         String?
  isSuperadmin     Boolean   @default(false)
  themeMode        String    @default("black")
  remindersEnabled      Boolean   @default(false)
  emailRemindersEnabled Boolean   @default(false)
  reminderMinutesBeforeDeadline Int @default(30)
  reminderEmail         String?
  reminderEmailConfirmedAt DateTime?

  // Auth Relations
  sessions      Session[]
  accounts      Account[]

  // Domain Relations
  leaguesOwned      League[]           @relation("OwnedLeagues")
  memberships       LeagueMember[]
  predictions       Prediction[]
  winnerPredictions WinnerPrediction[] @relation("UserWinnerPredictions")
  winnerPredictionHistories WinnerPredictionHistory[]
  standings         Standing[]
  adminActionLogs   AdminActionLog[]
  oddsSnapshots     OddsSnapshot[]
  oddsRefreshUsages UserOddsRefreshUsage[]
  reminderLogs      ReminderLog[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ─── DOMAIN MODELS (La Polla 2026 Models) ─────────────────────────────────────

model Team {
  // Existing fields above
  championPicks        ChampionPick[]        @relation("TeamChampionPicks")
  teamTournamentStatuses TeamTournamentStatus[] @relation("TeamStatuses")
  championOddsSnapshots ChampionOddsSnapshot[] @relation("TeamOddsSnapshots")
  code String @id // e.g. "ARG", "BRA", "MEX"
  name String
  hue  Int    // For circular gradients

  homeMatches       Match[]            @relation("HomeTeamMatches")
  awayMatches       Match[]            @relation("AwayTeamMatches")
  winnerPredictions WinnerPrediction[] @relation("TeamWinnerPredictions")
  oddsSnapshots     OddsSnapshot[]
  h2hHomeSnapshots  HeadToHeadSnapshot[] @relation("H2HHomeTeam")
  h2hAwaySnapshots  HeadToHeadSnapshot[] @relation("H2HAwayTeam")
  aliases           TeamAlias[]
  suggestedProviderOutcomes ProviderTeamOutcome[] @relation("SuggestedProviderTeam")

  @@map("team")
}

model Match {
  id           String      @id @default(cuid())
  phase        String      // "groups" | "r32" | "r16" | "quarters" | "semis" | "final"
  group        String?     // e.g. "A", "B" (null for knockouts)
  jornada      String      // e.g. "Fecha 1", "Fecha 2", "Octavos de Final"
  homeTeamCode String
  awayTeamCode String
  homeScore    Int?
  awayScore    Int?
  kickoffUtc   DateTime
  status       String      // "open" | "soon" | "live" | "result"
  venue        String
  city         String

  // Knockout & Results details
  resultStatus            String?   // "scheduled" | "closed_pending_result" | "final" | "postponed" | "cancelled"
  winnerTeamCode          String?
  wentToExtraTime         Boolean   @default(false)
  wentToPenalties         Boolean   @default(false)
  homePenaltyScore        Int?
  awayPenaltyScore        Int?
  resultSource            String?   // e.g. "api-football"
  resultFetchedAt         DateTime?
  resultUpdatedAt         DateTime?
  resultVerifiedById      String?
  resultNotes             String?

  homeTeam Team @relation("HomeTeamMatches", fields: [homeTeamCode], references: [code])
  awayTeam Team @relation("AwayTeamMatches", fields: [awayTeamCode], references: [code])

  predictions       Prediction[]
  oddsSnapshots     OddsSnapshot[]
  oddsRefreshUsages UserOddsRefreshUsage[]
  h2hSnapshot       HeadToHeadSnapshot?
  reminderLogs      ReminderLog[]

  @@index([phase, status])
  @@index([kickoffUtc])
  @@map("match")
}

model League {
  // Existing fields above
  championPicks        ChampionPick[]        @relation("LeagueChampionPicks")
  teamTournamentStatuses TeamTournamentStatus[] @relation("LeagueTeamStatuses")
  championOddsSnapshots ChampionOddsSnapshot[] @relation("LeagueOddsSnapshots")
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  inviteCode        String             @unique
  createdBy         String
  status            String             @default("active") // "active" | "archived"
  createdAt         DateTime           @default(now())
  isDefault         Boolean            @default(false)
  isActive          Boolean            @default(true)
  entryFee          Float              @default(0.0) // Cuota por usuario
  currency          String             @default("PEN") // Moneda, e.g. "PEN"
  prizePoolOverride Float?
  payoutRules       String?
  autoJoin          Boolean            @default(false) // Whether approved users auto-join this pool
  inviteEnabled     Boolean            @default(true)  // Whether joining by invite code is enabled
  championDeadline  DateTime?
  championPoints    Int                @default(10)
  pointsExactScore  Int                @default(5)
  pointsWinner      Int                @default(3)
  pointsDraw        Int                @default(3)
  pointsConsolation Int                @default(1)
  showOdds          Boolean            @default(true)
  showH2H           Boolean            @default(true)
  championTeamCode  String?
  knockoutOutcomeBasis String            @default("qualified_team") // "qualified_team" | "score_result"
  competitionType   CompetitionType    @default(full_prediction)



  owner             User               @relation("OwnedLeagues", fields: [createdBy], references: [id])
  members           LeagueMember[]
  predictions       Prediction[]
  winnerPredictions WinnerPrediction[] @relation("LeagueWinnerPredictions")
  winnerPredictionHistories WinnerPredictionHistory[]
  standings         Standing[]
  reminderLogs      ReminderLog[]

  @@map("league")
}

model LeagueMember {
  id            String   @id @default(cuid())
  leagueId      String
  userId        String
  role          String   @default("member") // "owner" | "admin" | "member"
  isParticipant Boolean  @default(true)
  joinedAt      DateTime @default(now())

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId])
  @@map("league_member")
}

model Prediction {
  id             String   @id @default(cuid())
  userId         String
  leagueId       String
  matchId        String
  homePrediction Int
  awayPrediction Int
  pointsEarned   Int?
  scoreType      String?  // "exact" | "tendency" | "consolation" | "miss"
  updatedAt      DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId, matchId])
  @@index([matchId])
  @@index([userId, leagueId])
  @@map("prediction")
}

model Standing {
  id           String @id @default(cuid())
  leagueId     String
  userId       String
  block        String // "groups" | "knockout" | "global"
  points       Int    @default(0)
  exacts       Int    @default(0)
  tendencies   Int    @default(0)
  consolations Int    @default(0)
  misses       Int    @default(0)
  rank         Int    @default(0)
  previousRank Int    @default(0)

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([leagueId, userId, block])
  @@index([leagueId, block])
  @@map("standing")
}

model AdminActionLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // e.g. "update_score", "edit_match"
  target    String?  // e.g. "match:m-1", "user:u-2"
  details   String?  // JSON string or summary of changes
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_action_log")
}

model WinnerPrediction {
  id                       String    @id @default(cuid())
  userId                   String
  leagueId                 String
  teamCode                 String
  pointsEarned             Int?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime @updatedAt
  // Correction System Fields
  correctionAllowed        Boolean   @default(false)
  correctionAllowedUntil   DateTime?
  correctionReason         String?
  correctionAuthorizedById String?

  // Competition Type awareness (optional, no column needed now)
  // competitionType          CompetitionType? // can be derived via league.competitionType

  user   User   @relation("UserWinnerPredictions", fields: [userId], references: [id], onDelete: Cascade)
  league League @relation("LeagueWinnerPredictions", fields: [leagueId], references: [id], onDelete: Cascade)
  team   Team   @relation("TeamWinnerPredictions", fields: [teamCode], references: [code], onDelete: Cascade)

  @@unique([userId, leagueId])
  @@map("winner_prediction")
}

model ChampionPick {
  id                String   @id @default(cuid())
  leagueId          String
  userId            String
  teamCode          String
  submittedAt       DateTime @default(now())
  lockedAt          DateTime?
  correctionAllowed Boolean   @default(false)
  correctedByAdminId String?
  correctedAt       DateTime?
  lastCorrectionReason String?
  previousTeamCode  String?
  newTeamCode       String?

  user   User   @relation("UserChampionPicks", fields: [userId], references: [id], onDelete: Cascade)
  league League @relation("LeagueChampionPicks", fields: [leagueId], references: [id], onDelete: Cascade)
  team   Team   @relation("TeamChampionPicks", fields: [teamCode], references: [code], onDelete: Cascade)

  @@unique([leagueId, userId])
}

model TeamTournamentStatus {
  id               String   @id @default(cuid())
  userId   String?  // optional reference to User
  user   User?   @relation("UserTeamStatuses", fields: [userId], references: [id], onDelete: Cascade)
  teamCode String
  team   Team   @relation("TeamStatuses", fields: [teamCode], references: [code], onDelete: Cascade)
  leagueId String
  status String @default("unknown") // unknown/active/eliminated/runner_up/champion
  eliminatedAt DateTime?
  eliminatedInMatchId String?
  finalRank Int?
  notes String?
  updatedAt DateTime @updatedAt
  updatedById String?
  league League @relation("LeagueTeamStatuses", fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([teamCode, leagueId])
}

model ChampionOddsSnapshot {
  id                String   @id @default(cuid())
  leagueId          String
  teamCode          String
  provider          String
  bookmaker         String
  decimalOdds       Float
  impliedProbability Float   @default(0)
  capturedAt        DateTime @default(now())
  sourceMarket      String   // e.g. "outright_winner"
  rawSourceRef      String?
  userId   String?  // optional reference to User
  user     User?   @relation("UserOddsSnapshots", fields: [userId], references: [id], onDelete: Cascade)

  league League @relation("LeagueOddsSnapshots", fields: [leagueId], references: [id], onDelete: Cascade)
  team   Team   @relation("TeamOddsSnapshots", fields: [teamCode], references: [code], onDelete: Cascade)
}

model WinnerPredictionHistory {
  id                   String   @id @default(cuid())
  leagueId             String
  userId               String
  oldTeamCode          String?
  newTeamCode          String
  actionType           String   // "created" | "correction_authorized" | "changed_by_user" | "changed_by_admin" | "correction_rejected"
  authorizedById       String?
  changedById          String?
  reason               String?
  createdAt            DateTime @default(now())
  visibleToParticipants Boolean  @default(true)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@map("winner_prediction_history")
}

model OddsSnapshot {
  id                    String   @id @default(cuid())
  matchId               String
  provider              String   // e.g. "odds-api-io", "the-odds-api", "manual"
  bookmaker             String   // e.g. "Betsson", "Bet365"
  marketType            String   // e.g. "match_winner"
  outcomeType           String   // e.g. "home", "draw", "away"
  teamCode              String?  // References team selection if applicable
  outcomeLabel          String   // e.g. "Argentina", "Empate"
  decimalOdds           Float
  impliedProbability    Float
  normalizedProbability Float?
  capturedAt            DateTime @default(now())
  visibility            String   // "global" | "user_private"
  userId                String?
  sourceType            String   // "api" | "manual"
  rawPayload            String?  // JSON string
  createdAt             DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  team  Team? @relation(fields: [teamCode], references: [code], onDelete: Cascade)

  @@index([matchId, marketType, visibility, userId, capturedAt])
  @@map("odds_snapshot")
}

model UserOddsRefreshUsage {
  id             String   @id @default(cuid())
  userId         String
  dateKey        String   // YYYY-MM-DD
  timezone       String   // e.g. "America/Lima"
  usedAt         DateTime @default(now())
  matchId        String
  provider       String
  oddsSnapshotId String?

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@map("user_odds_refresh_usage")
}

model HeadToHeadSnapshot {
  id              String   @id @default(cuid())
  matchId         String   @unique
  provider        String   @default("api-football")
  homeTeamCode    String
  awayTeamCode    String
  totalMatches    Int
  homeWins        Int
  draws           Int
  awayWins        Int
  homeGoals       Int
  awayGoals       Int
  lastMatchesJson String?  // JSON string of past match details
  capturedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  match    Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homeTeam Team  @relation("H2HHomeTeam", fields: [homeTeamCode], references: [code], onDelete: Cascade)
  awayTeam Team  @relation("H2HAwayTeam", fields: [awayTeamCode], references: [code], onDelete: Cascade)

  @@map("head_to_head_snapshot")
}

model ReminderLog {
  id                         String   @id @default(cuid())
  userId                     String
  leagueId                   String
  matchId                    String
  reminderType               String   @default("match_prediction_deadline")
  channel                    String   @default("email")
  scheduledFor               DateTime
  sentAt                     DateTime?
  status                     String
  provider                   String   @default("resend")
  providerMessageId          String?
  errorMessage               String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, leagueId, matchId, reminderType, channel])
  @@index([userId])
  @@index([matchId])
  @@index([leagueId])
  @@map("reminder_log")
}

model ProviderCredential {
  id                    String    @id @default(cuid())
  provider              String    @unique
  encryptedApiKey       String?
  maskedApiKey          String?
  isActive              Boolean   @default(false)
  lastStatus            String?
  lastCheckedAt         DateTime?
  lastError             String?
  lastRequestsRemaining Int?
  lastRequestsUsed      Int?
  lastRequestCost       Int?
  lastResetAt           DateTime?
  lastResetInSeconds    Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  updatedByUserId       String?

  @@map("provider_credential")
}

model TeamAlias {
  id              String   @id @default(cuid())
  teamCode        String
  provider        String
  alias           String
  normalizedAlias String
  confidence      Float?
  source          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdByUserId String?

  team Team @relation(fields: [teamCode], references: [code], onDelete: Cascade)

  @@unique([provider, normalizedAlias])
  @@index([teamCode])
  @@map("team_alias")
}

model ProviderTeamOutcome {
  id                String   @id @default(cuid())
  provider          String
  marketType        String
  rawName           String
  normalizedName    String
  samplePayload     String?
  firstSeenAt       DateTime @default(now())
  lastSeenAt        DateTime @default(now())
  suggestedTeamCode String?
  confidence        Float?
  reason            String?
  status            String   @default("unmatched")

  suggestedTeam Team? @relation("SuggestedProviderTeam", fields: [suggestedTeamCode], references: [code], onDelete: SetNull)

  @@unique([provider, marketType, normalizedName])
  @@index([status, lastSeenAt])
  @@index([suggestedTeamCode])
  @@map("provider_team_outcome")
}

model ProviderStatus {
  provider         String   @id // "odds-api-io", "the-odds-api", "api-football"
  cooldownUntil    DateTime
  lastStatus       Int?
  lastErrorMessage String?
  updatedAt        DateTime @updatedAt

  @@map("provider_status")
}

model AppSettings {
  key         String   @id
  value       String
  updatedAt   DateTime @updatedAt
  updatedById String?

  @@map("app_settings")
}


